<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="InputDirectory" value="..\Sample" />
    <add key="OutputDirectory" value="..\Sample\json-output" />
    <add key="OcrProvider" value="Aliyun" />
    <add key="OcrLanguage" value="zh-Hans" />
    <add key="AccessKeyID" value="xxxx" />
    <add key="AccessKeySecret" value="xxxx" />
    <add key="AliOcrEndpoint" value="ocr-api.cn-hangzhou.aliyuncs.com" />
    <add key="EasyOcrEndpoint" value="http://127.0.0.1:8000" />
    <add key="PaddleEndpoint" value="http://127.0.0.1:8001" />
    <add key="LocalOcrTimeoutSeconds" value="300" />
    <add key="LocalDbConnectionString" value="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=OcrLocalDb;Integrated Security=True;TrustServerCertificate=True;" />
    <add key="AiFallbackEnabled" value="true" />
    <add key="AiProvider" value="ollama" />
    <add key="OllamaEndpoint" value="http://127.0.0.1:11434" />
    <add key="OllamaModel" value="qwen2.5:7b" />
    <add key="OllamaTimeoutSeconds" value="600" />
    <add key="BailianEndpoint" value="https://dashscope.aliyuncs.com/compatible-mode/v1" />
    <!--deepseek-v4-flash/qwen3.6-flash -->
    <add key="BailianModel" value="qwen-plus" />
    <add key="BailianApiKey" value="sk-xxxx" />
    <add key="BailianTimeoutSeconds" value="600" />
  </appSettings>
</configuration>
